# RoninStandAlone — self / cloud-hosted deployment config. Copy to deploy/.env.
# Secrets: in real deployments inject via your platform / 1Password — do NOT commit .env.

# --- Storage base (the one knob that switches local vs cloud) ---
# Local volume (default):
RONIN_DELTA_BASE=/data/delta
# Cloud object store (pick one) — the sidecar (delta-rs) writes Delta directly:
#   RONIN_DELTA_BASE=s3://my-bucket/ronin
#   RONIN_DELTA_BASE=gs://my-bucket/ronin
#   RONIN_DELTA_BASE=az://my-container/ronin

# --- Object-store credentials (only when RONIN_DELTA_BASE is a cloud URI) ---
# AWS S3 / S3-compatible (MinIO, R2):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
# Single-writer (ADR-0026): on native AWS S3 set this true (no lock service needed).
# Leave empty for R2/MinIO/GCS (native conditional-put).
AWS_S3_ALLOW_UNSAFE_RENAME=
# GCS:
GOOGLE_SERVICE_ACCOUNT=
# Azure Blob / ADLS:
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

# --- Server ---
RONIN_PORT=3000
RONIN_PUBLIC_URL=http://localhost:3000
RONIN_LOG_LEVEL=info

# --- PHI / security (REQUIRED before real PHI; not wired in this build) ---
# This build has NO auth/TLS — synthetic data only. Before any real PHI:
#   - put a TLS-terminating proxy in front (transmission security)
#   - wire SMART/UDAP auth (ADR-0006) + AuditEvent capture (ADR-0016)
#   - enable object-store encryption at rest (SSE/KMS)
# See memory: phi-security-standards.
